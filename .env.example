# JARVIS NEWS - variables de entorno (copia este archivo como .env)

# Puerto del servidor
PORT=3000

# (OPCIONAL) NewsAPI.org - si quieres complementar con NewsAPI ademas del RSS.
# Consigue una key gratis en https://newsapi.org  y descomenta:
# NEWSAPI_KEY=tu_api_key_aqui

# (OPCIONAL) Credenciales Firebase para persistir favoritos en la nube.
# Ver README -> "Migrar a Firebase".
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
